    <!-- 交叉口定义 -->
    <junction id="4" name="Y型交叉口">
        <roadLink>
            <link id="1" contactPoint="end"/>
            <link id="2" contactPoint="end"/>
            <link id="3" contactPoint="end"/>
            <link id="5" contactPoint="end"/>
            <link id="6" contactPoint="end"/>
        </roadLink>
        <connection id="1" incomingRoad="3" connectingRoad="5" contactPoint="start">
            <laneLink from="1" to="-1"/>
            <laneLink from="2" to="-2"/>
        </connection>
        <connection id="2" incomingRoad="3" connectingRoad="6" contactPoint="start">
            <laneLink from="1" to="-1"/>
            <laneLink from="2" to="-2"/>
        </connection>
        <connection id="3" incomingRoad="5" connectingRoad="3" contactPoint="start">
            <laneLink from="1" to="-1"/>
            <laneLink from="2" to="-2"/>
        </connection>
        <connection id="3" incomingRoad="5" connectingRoad="6" contactPoint="start">
            <laneLink from="1" to="-1"/>
            <laneLink from="2" to="-2"/>
        </connection>
        <connection id="4" incomingRoad="6" connectingRoad="3" contactPoint="start">
            <laneLink from="1" to="-1"/>
            <laneLink from="2" to="-2"/>
        </connection>
        <connection id="5" incomingRoad="6" connectingRoad="5" contactPoint="start">
            <laneLink from="1" to="-1"/>
            <laneLink from="2" to="-2"/>
        </connection>
    </junction>
