    <!-- 道路5：连接道路3到道路2 -->
    <road name="Road5" length="10.0" id="5" junction="4">
        <link>
            <predecessor elementType="road" elementId="3" contactPoint="end" />
            <successor elementType="road" elementId="2" contactPoint="start" />
        </link>
        <planView>
            <geometry s="0.0" x="2.5" y="1" hdg="240.0" length="10.0">
